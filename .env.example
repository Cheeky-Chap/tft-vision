# TFT Vision — 환경 설정 예시
# 실제 사용 시 .env로 복사하고 값 채울 것 (.env는 git 제외됨)

# 캡처 설정
CAPTURE_INTERVAL=1.0
BATTLE_CAPTURE_INTERVAL=0.3
MONITOR_INDEX=1

# 저장 경로 (기본값 사용 시 주석 처리)
# CAPTURES_DIR=captures
# CROPS_DIR=crops
# LOGS_DIR=logs

# 디버그
SHOW_PREVIEW=false
LOG_LEVEL=INFO

# AI-SERVER 연동 (추후 MVP2+)
# AI_SERVER_URL=http://192.168.x.x:8000/api/tft/event
# AI_SERVER_API_KEY=
